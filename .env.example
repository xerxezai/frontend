# Frontend environment configuration
# Copy to .env (development) or .env.production (production build) and fill in real values.
VITE_APP_BASE_PATH=/
VITE_API_BASE_URL=https://your-backend.example.com/api/v1
VITE_APP_TITLE=XERXEZ Application
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true
VITE_BRAND_NAME=XERXEZ
VITE_BRAND_TAGLINE=AI-Powered ERP, MLOpsSecOps & Cloud Services for Modern Enterprises
VITE_BRAND_EMAIL=hello@example.com
VITE_BRAND_SITE=https://example.com
