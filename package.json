{
  "name": "xerxez-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "XERXEZ - AI-Powered ERP & Enterprise Solutions frontend",
  "keywords": [
    "react",
    "typescript",
    "vite",
    "erp",
    "xerxez"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:app && npm run build:docs",
    "build:app": "tsc -b && vite build",
    "build:docs": "node scripts/build-docs.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "serve": "npm run build && npm run preview",
    "clean": "rimraf dist",
    "docs:dev": "npm run dev",
    "docs:build": "npm run build:docs",
    "start": "npm run dev",
    "migrate": "node scripts/migrate.js",
    "migrate:verify": "node scripts/migrate.js verify",
    "migrate:health": "node scripts/migrate.js health",
    "migrate:backup": "node scripts/migrate.js backup"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.1.2",
    "@paper-design/shaders-react": "^0.0.76",
    "@types/react-helmet": "^6.1.11",
    "aos": "^2.3.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "gsap": "^3.13.0",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.6.3",
    "react-toastify": "^11.0.5",
    "recharts": "^3.9.2",
    "sass": "^1.89.2",
    "split-type": "^0.3.4",
    "swiper": "^11.2.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.3",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
